---
// Ruta protegida con contrasena (HTTP Basic Auth) a nivel de servidor.
// La contrasena vive en Cloudflare Pages como variable de entorno secreta
// llamada PRESENTACION_PASSWORD (Settings -> Environment variables).
// En local, crea un archivo .dev.vars con: PRESENTACION_PASSWORD=tu-clave
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import SlideHeader from "../components/presentacion/SlideHeader.astro";
import Notes from "../components/presentacion/Notes.astro";
import Kpi from "../components/presentacion/Kpi.astro";
import Step from "../components/presentacion/Step.astro";

const runtimeEnv = Astro.locals.runtime?.env ?? {};
const expectedPassword = runtimeEnv.PRESENTACION_PASSWORD;

function isAuthorized(header, password) {
  if (!password) return false;
  if (!header || !header.startsWith("Basic ")) return false;
  try {
    const decoded = atob(header.slice(6));
    const separatorIndex = decoded.indexOf(":");
    return decoded.slice(separatorIndex + 1) === password;
  } catch {
    return false;
  }
}

const authHeader = Astro.request.headers.get("authorization");

console.log("presentacion.astro DEBUG", {
  hasRuntime: typeof Astro.locals.runtime,
  runtimeEnvKeys: Object.keys(runtimeEnv),
  expectedPasswordType: typeof expectedPassword,
  authHeaderPresent: !!authHeader,
});

if (!isAuthorized(authHeader, expectedPassword)) {
  return new Response("Autenticación requerida", {
    status: 401,
    headers: { "WWW-Authenticate": 'Basic realm="Rotary Casa Flora"' },
  });
}

console.log("presentacion.astro DEBUG: auth passed, about to render");
---

<Layout title="Rotary Casa Flora — Propuesta de Fundación" noindex={true}>
  <div class="min-h-screen">
    <header class="flex items-center justify-between border-b border-white/10 px-6 py-4 lg:px-10">
      <div class="flex items-center gap-3">
        <img src="/images/logo-rotaract-flor.png" alt="Rotaract Casa Flora" class="h-9 w-auto" />
        <span class="hidden text-xs uppercase tracking-[0.15em] text-white/40 sm:inline">
          Documento confidencial — Uso interno del comité fundador
        </span>
      </div>
      <div class="flex items-center gap-5">
        <button
          id="toggle-notes"
          type="button"
          aria-pressed="false"
          class="flex items-center gap-2 rounded-full border border-white/10 px-3 py-1.5 text-xs font-semibold text-white/60 transition-colors hover:border-gold-soft hover:text-gold-soft"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-white/30"></span>
          <span id="toggle-notes-label">Mostrar notas del orador</span>
        </button>
        <a href="/" class="text-xs font-semibold text-gold-soft transition-colors hover:text-gold">
          ← Volver al sitio
        </a>
      </div>
    </header>
    <p class="border-b border-white/10 bg-magenta-deep/20 px-6 py-2 text-center text-[11px] text-white/60 lg:px-10">
      🔒 Las notas del orador están ocultas por defecto — solo tú las ves al activarlas. No las muestres si vas a compartir pantalla frente a los invitados.
    </p>

    <main class="mx-auto max-w-5xl px-6 py-14 lg:px-10">
      <!-- SLIDE 1 — Portada -->
      <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-charcoal via-obsidian to-obsidian p-10 sm:p-16">
        <div class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-magenta/25 blur-[100px]"></div>
        <div class="absolute -bottom-24 -right-16 h-64 w-64 rounded-full bg-gold/15 blur-[100px]"></div>
        <p class="relative text-xs uppercase tracking-[0.2em] text-white/40">01 / 09 — Portada</p>
        <img src="/images/logo-rotaract-flor.png" alt="" class="relative mt-8 h-14 w-auto" />
        <h1 class="relative mt-6 font-display text-5xl font-extrabold leading-[1.05] sm:text-6xl">
          ROTARY<br />
          <span class="text-gradient-brand">CASA FLORA</span>
        </h1>
        <p class="relative mt-5 max-w-lg text-lg text-white/65">
          Dos generaciones. Una sola manera de dejar huella.
        </p>
        <div class="relative mt-12 flex items-center gap-4 divider-gold pt-6">
          <span class="pt-6 text-xs uppercase tracking-widest text-white/40">Propuesta de Fundación</span>
          <span class="pt-6 text-xs uppercase tracking-widest text-white/40">2026 · Cúcuta, Colombia</span>
        </div>
      </section>
      <Notes>
        <p><em>"Gracias por abrirnos un espacio en sus agendas — sabemos lo que vale una hora del tiempo de las personas que están en esta sala."</em></p>
        <p>Pausa breve tras revelar el título. Frase de anclaje: <em>"Lo que van a ver hoy no es una propuesta más. Es una invitación a fundar algo que nos va a sobrevivir a todos los que estamos en esta sala."</em></p>
        <p class="tone">Tono: cálido, seguro, sin prisa.</p>
      </Notes>

      <!-- SLIDE 2 — El Nuevo Rotary -->
      <SlideHeader tag="02 / 09 — El Nuevo Rotary" kicker="Actualización institucional" />
      <section class="rounded-3xl border border-white/10 bg-charcoal p-10 sm:p-14">
        <h2 class="font-display text-3xl font-bold sm:text-4xl">Esto ya no es el Rotaract que dejaste hace 20 años</h2>
        <div class="mt-10 grid gap-10 sm:grid-cols-2">
          <div>
            <p class="text-xs uppercase tracking-widest text-white/40">Lo que quizás recuerdas</p>
            <ul class="mt-4 space-y-3 text-sm text-white/40 line-through">
              <li>"El programa de jóvenes" de un club padrino</li>
              <li>Sin voto real en las decisiones distritales</li>
              <li>Actividades vistas como "de práctica"</li>
              <li>Tutelaje permanente de un club Rotario</li>
            </ul>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-gold-soft">Lo que es, desde 2020</p>
            <ul class="mt-4 space-y-3 text-sm text-white/75">
              <li>Membresía de <b class="text-gold-soft">pleno derecho</b> de Rotary International</li>
              <li>Mismas cuotas, mismos deberes, mismo peso institucional</li>
              <li>Autonomía total — sin club padrino, sin tutelaje</li>
              <li>Voz y voto en el mismo ecosistema rotario que ustedes conocieron</li>
            </ul>
          </div>
        </div>
      </section>
      <Notes>
        <p>Nombrar el supuesto que probablemente cargan: <em>"muchos de ustedes salieron de Rotaract cuando todavía era la antesala del Rotary de verdad."</em> Explicar en una frase la reforma de 2020, sin tecnicismos.</p>
        <p>Cerrar con: <em>"El club que ustedes quieren fundar hoy, y el club que nosotros ya somos hoy, pertenecen exactamente a la misma categoría institucional. No hay jerarquía entre nosotros. Hay paridad."</em></p>
        <p class="tone">Tono: informativo, es una corrección de percepción, no una lección.</p>
      </Notes>

      <!-- SLIDE 3 — Legado Casa Flora -->
      <SlideHeader tag="03 / 09 — Legado Casa Flora" kicker="Quiénes somos" />
      <section class="rounded-3xl border border-white/10 bg-charcoal p-10 sm:p-14">
        <h2 class="font-display text-3xl font-bold sm:text-4xl">Tres años construyendo lo que otros tardan una década en lograr</h2>
        <div class="mt-10 grid gap-10 lg:grid-cols-[1.2fr_1fr]">
          <ul class="space-y-5">
            <li><b class="text-white">Fundación</b><br /><span class="text-sm text-white/55">Primer club Rotaract de Colombia y de la Zona 25A sin club padrino</span></li>
            <li><b class="text-white">Consolidación</b><br /><span class="text-sm text-white/55">Identidad de marca propia, cultura de excelencia instalada</span></li>
            <li><b class="text-gold-soft">Hoy</b><br /><span class="text-sm text-white/55">Mejor Club del Distrito — reconocimiento, no autopercepción</span></li>
          </ul>
          <div class="grid gap-3">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4"><p class="font-display text-lg font-bold text-magenta-bright">clubrotaractcasaflora.org</p><p class="text-xs text-white/45">Presencia web propia, en español e inglés</p></div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4"><p class="font-display text-lg font-bold text-magenta-bright">@rotaractcasaflora</p><p class="text-xs text-white/45">Comunidad digital activa en Instagram</p></div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4"><p class="font-display text-lg font-bold text-magenta-bright">3+ años</p><p class="text-xs text-white/45">De continuidad operativa ininterrumpida</p></div>
          </div>
        </div>
      </section>
      <Notes>
        <p><em>"No les vamos a pedir que nos crean. Les vamos a mostrar exactamente dónde verificarlo."</em> Si el formato lo permite, abrir el sitio o el Instagram en vivo dos segundos.</p>
        <p class="tone">Tono: seguridad tranquila, sin perseguir el aplauso.</p>
      </Notes>

      <!-- SLIDE 4 — RYLA (obra bandera) -->
      <SlideHeader tag="04 / 09 — Obra Bandera" kicker="Nuestra especialidad" />
      <section class="rounded-3xl border border-gold-soft/25 bg-gradient-to-br from-charcoal to-obsidian p-10 sm:p-14">
        <h2 class="font-display text-3xl font-bold sm:text-4xl">RYLA: liderazgo en estado puro, y lo hacemos mejor que nadie</h2>
        <div class="mt-8 grid gap-10 lg:grid-cols-2">
          <div>
            <p class="text-xs uppercase tracking-widest text-gold-soft">¿Qué es RYLA?</p>
            <p class="mt-3 text-sm leading-relaxed text-white/70">
              RYLA (<i>Rotary Youth Leadership Awards</i>) es el programa insignia de Rotary International
              para formar líderes jóvenes a través de experiencias intensivas de liderazgo, trabajo en
              equipo y crecimiento personal.
            </p>
            <p class="mt-4 text-sm leading-relaxed text-white/70">
              No es un taller más — es la vitrina donde un club demuestra si realmente sabe formar líderes,
              o si solo habla de hacerlo.
            </p>
          </div>
          <div class="grid gap-3">
            <div class="rounded-2xl border border-gold-soft/25 bg-gold-soft/5 p-5">
              <p class="font-display text-2xl font-extrabold text-gold-soft">3 ediciones</p>
              <p class="mt-1 text-xs text-white/50">de RYLA organizadas y ejecutadas por Casa Flora</p>
            </div>
            <div class="rounded-2xl border border-gold-soft/25 bg-gold-soft/5 p-5">
              <p class="font-display text-2xl font-extrabold text-gold-soft">+60 líderes certificados</p>
              <p class="mt-1 text-xs text-white/50">jóvenes formados y certificados a través de nuestros programas</p>
            </div>
          </div>
        </div>
        <p class="mt-8 text-center font-display text-lg font-semibold text-gold-soft">
          No solo hablamos de liderazgo. Lo certificamos.
        </p>
      </section>
      <Notes>
        <p>Esta es prueba concreta de capacidad operativa, no una promesa: <em>"RYLA es lo más difícil de ejecutar bien en todo el ecosistema rotario — logística, convocatoria, contenido, certificación. Nosotros ya lo dominamos."</em></p>
        <p>Invitarlos a imaginar un RYLA de Rotary Casa Flora a mayor escala, con su respaldo empresarial detrás.</p>
        <p class="tone">Tono: orgullo profesional, sin arrogancia — es un hecho, no una opinión.</p>
      </Notes>

      <!-- SLIDE 5 — Cifras -->
      <SlideHeader tag="05 / 09 — Cifras" kicker="El músculo financiero y social" />
      <section class="rounded-3xl border border-white/10 bg-charcoal p-10 sm:p-14">
        <h2 class="font-display text-3xl font-bold sm:text-4xl">Los números no se improvisan, se ejecutan</h2>
        <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
          <Kpi n="+10M" c="gold" d="COP donados a causas comunitarias y a la Fundación Rotaria" />
          <Kpi n="+6" c="magenta" d="Proyectos comunitarios ejecutados con evidencia documentada" />
          <Kpi n="100%" c="gold" d="De rendición de cuentas — cada peso, trazable" />
          <Kpi n="3+" c="magenta" d="Años de operación continua, sin pausas ni reinicios" />
        </div>
      </section>
      <Notes>
        <p><em>"Esto no es filantropía informal. Es una operación con controles, igual que las que ustedes dirigen todos los días."</em> Pausar en el 100% de rendición de cuentas.</p>
        <p class="tone">Tono: ejecutivo, directo, casi de sala de juntas.</p>
      </Notes>

      <!-- SLIDE 6 — Rompehielos -->
      <SlideHeader tag="06 / 09 — Rompehielos" kicker="Antes de seguir, una confesión" />
      <section class="rounded-3xl border border-white/10 bg-charcoal p-10 text-center sm:p-16">
        <p class="mx-auto max-w-2xl text-xl leading-relaxed text-white/85">
          "Cuando vimos la lista de asistentes a esta reunión, por un segundo pensamos que nos habíamos
          equivocado de sala — y que estábamos a punto de presentarle esto a la nueva Junta Directiva de
          la Cámara de Comercio."
        </p>
        <p class="mx-auto mt-6 max-w-2xl text-xl font-semibold leading-relaxed text-gold-soft">
          Pero no. Resulta que ese es exactamente el nivel de liderazgo que un Club Rotario debería tener
          desde el primer día.
        </p>
      </section>
      <Notes>
        <p>Guion literal, con calma y pausa marcada: <em>"...y que estábamos a punto de presentarle esto a la nueva Junta Directiva de la Cámara de Comercio de Cúcuta." [pausa para la risa] "Pero no..."</em></p>
        <p class="tone">Tono: humor gremial, deadpan, cálido — es un halago disfrazado de chiste. No apresurar la siguiente slide.</p>
      </Notes>

      <!-- SLIDE 7 — Match Perfecto -->
      <SlideHeader tag="07 / 09 — Match Perfecto" kicker="La propuesta de valor" />
      <section class="rounded-3xl border border-white/10 bg-charcoal p-10 sm:p-14">
        <h2 class="font-display text-3xl font-bold sm:text-4xl">El engranaje que faltaba</h2>
        <div class="mt-10 grid gap-10 sm:grid-cols-2">
          <div>
            <p class="text-xs uppercase tracking-widest text-gold-soft">Lo que ustedes aportan</p>
            <ul class="mt-4 space-y-3 text-sm text-white/75">
              <li>Trayectoria empresarial de décadas</li>
              <li>Capital y solidez financiera</li>
              <li>Red de contactos ya consolidada</li>
              <li>Visión estratégica de largo plazo</li>
            </ul>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-magenta-bright">Lo que aporta Casa Flora</p>
            <ul class="mt-4 space-y-3 text-sm text-white/75">
              <li>Metodología operativa ya comprobada</li>
              <li>Energía y velocidad de ejecución</li>
              <li>Marca ya posicionada como líder distrital</li>
              <li>Relevo generacional garantizado</li>
            </ul>
          </div>
        </div>
        <p class="mt-10 text-center font-display text-lg font-semibold text-gold-soft">
          No empezamos desde cero. Empezamos desde la cima.
        </p>
      </section>
      <Notes>
        <p>Centro emocional del pitch — bajar el ritmo. <em>"Esto no es mentoría. No es caridad. Esto es un match estratégico entre iguales."</em></p>
        <p class="tone">Tono: el más serio y sincero de toda la presentación.</p>
      </Notes>

      <!-- SLIDE 8 — Ruta de Charter -->
      <SlideHeader tag="08 / 09 — Ruta de Charter" kicker="Requisitos legales" />
      <section class="rounded-3xl border border-white/10 bg-charcoal p-10 sm:p-14">
        <h2 class="font-display text-3xl font-bold sm:text-4xl">El camino formal, sin curva de aprendizaje</h2>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <Step n="01" t="Mínimo 20 socios fundadores — ya tenemos un pipeline de perfiles afines mapeado" />
          <Step n="02" t="Elección de Oficiales del Club: Presidente, Secretario, Tesorero y Directores" />
          <Step n="03" t="Respaldo formal y aval de nuestro Distrito Rotario" />
          <Step n="04" t="Aprobación y entrega oficial del Charter por Rotary International" />
        </div>
        <p class="mt-8 text-center text-sm italic text-white/55">
          Nosotros ya recorrimos este camino una vez. Esta vez, lo recorremos junto a ustedes.
        </p>
      </section>
      <Notes>
        <p>El objetivo es bajar la ansiedad administrativa: <em>"La curva de aprendizaje, para ustedes, es cero."</em></p>
        <p class="tone">Tono: tranquilizador, logístico.</p>
      </Notes>

      <!-- SLIDE 9 — Cierre -->
      <SlideHeader tag="09 / 09 — Cierre" kicker="Llamado a la acción" />
      <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-obsidian via-[#1a0a12] to-[#241708] p-10 text-center sm:p-16">
        <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_0%,rgba(209,0,116,0.28),transparent_55%)]"></div>
        <h2 class="font-display text-3xl font-bold sm:text-4xl">¿Van a observar la historia, o van a firmarla?</h2>
        <span class="mt-8 inline-flex rounded-full bg-gradient-to-r from-magenta to-magenta-bright px-8 py-3 font-semibold">
          Sí, fundemos Rotary Casa Flora
        </span>
        <p class="mt-6 text-xs uppercase tracking-widest text-white/40">
          Próximo paso propuesto: [FECHA] — Firma de intención y cronograma de Charter
        </p>
      </section>
      <Notes>
        <p><em>"Rotary Casa Flora no se funda con nostalgia. Se funda con ustedes."</em> Dejar un silencio real tras la pregunta central.</p>
        <p class="tone">Tono: inspirador pero concreto — cerrar con una acción en el calendario, no con un "lo pensamos".</p>
      </Notes>

      <div class="h-10"></div>
    </main>
  </div>
</Layout>

<script>
  const button = document.getElementById("toggle-notes");
  const label = document.getElementById("toggle-notes-label");
  const notes = document.querySelectorAll(".presenter-notes");

  let visible = false;

  button?.addEventListener("click", () => {
    visible = !visible;
    notes.forEach((note) => note.classList.toggle("hidden", !visible));
    button.setAttribute("aria-pressed", String(visible));
    if (label) label.textContent = visible ? "Ocultar notas del orador" : "Mostrar notas del orador";
    const dot = button.querySelector("span");
    if (dot) dot.className = visible ? "h-1.5 w-1.5 rounded-full bg-magenta-bright" : "h-1.5 w-1.5 rounded-full bg-white/30";
  });
</script>
