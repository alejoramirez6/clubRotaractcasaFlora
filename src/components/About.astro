---
import Card from "./ui/Card.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const rotaryHref =
  lang === "en"
    ? "https://www.rotary.org/en/get-involved/rotaract-clubs"
    : "https://www.rotary.org/es/get-involved/rotaract-clubs";

const pillars = [
  { title: t("pillar1.title"), text: t("pillar1.text"), icon: "M12 3 3 7.5 12 12l9-4.5L12 3Zm-9 6v6l9 4.5 9-4.5V9l-9 4.5L3 9Z" },
  { title: t("pillar2.title"), text: t("pillar2.text"), icon: "M12 2 2 7l10 5 10-5-10-5Zm0 8v12M2 12v5l10 5 10-5v-5" },
  { title: t("pillar3.title"), text: t("pillar3.text"), icon: "M12 21c4-3 7-7.5 7-11.5A7 7 0 0 0 5 9.5C5 13.5 8 18 12 21Z" },
];
---

<section id="quienes-somos" class="relative py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-xs font-semibold uppercase tracking-[0.25em] text-magenta-bright">{t("about.eyebrow")}</span>
      <h2 class="mt-4 font-display text-4xl font-bold sm:text-5xl">
        {t("about.titleLine1")} <span class="text-gradient-brand">{t("about.titleHighlight")}</span>
      </h2>
      <p class="mt-5 text-white/65">
        {t("about.p1")}
      </p>
      <p class="mt-5 text-white/65">
        {t("about.p2")}
      </p>
      <a
        href={rotaryHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-gold-soft transition-colors hover:text-gold"
      >
        {t("about.learnMore")}
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        pillars.map((pillar) => (
          <Card class="group transition-transform duration-300 hover:-translate-y-1">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-magenta/20 to-gold/10">
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-gold-soft" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d={pillar.icon} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-6 font-display text-xl font-semibold">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/60">{pillar.text}</p>
          </Card>
        ))
      }
    </div>
  </div>
</section>
