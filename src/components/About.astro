---
import Card from "./ui/Card.astro";

const pillars = [
  {
    title: "Socios de Rotary",
    text: "Desde la reforma de 2020, Rotaract es un socio de pleno derecho de Rotary International, con voz, voto y representación directa en el ecosistema rotario mundial.",
    icon: "M12 3 3 7.5 12 12l9-4.5L12 3Zm-9 6v6l9 4.5 9-4.5V9l-9 4.5L3 9Z",
  },
  {
    title: "Liderazgo Profesional",
    text: "No somos un club social más. Somos una incubadora de líderes: jóvenes profesionales y estudiantes que ejecutan proyectos reales con estándares corporativos.",
    icon: "M12 2 2 7l10 5 10-5-10-5Zm0 8v12M2 12v5l10 5 10-5v-5",
  },
  {
    title: "Identidad Casa Flora",
    text: "El nombre nos define: florecemos donde otros solo observan. Cúcuta es nuestro territorio de impacto y cada socio es una raíz que sostiene el crecimiento del club.",
    icon: "M12 21c4-3 7-7.5 7-11.5A7 7 0 0 0 5 9.5C5 13.5 8 18 12 21Z",
  },
];
---

<section id="quienes-somos" class="relative py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-xs font-semibold uppercase tracking-[0.25em] text-magenta-bright">Evolución</span>
      <h2 class="mt-4 font-display text-4xl font-bold sm:text-5xl">
        Rotaract, hoy, es otra <span class="text-gradient-brand">liga</span>
      </h2>
      <p class="mt-5 text-white/65">
        Dejamos atrás la idea de "club juvenil de acompañamiento". Hoy somos una organización de
        liderazgo, servicio e impacto profesional que opera con la misma exigencia que cualquier
        junta directiva de alto nivel — y con el corazón de Casa Flora.
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        pillars.map((pillar) => (
          <Card class="group transition-transform duration-300 hover:-translate-y-1">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-magenta/20 to-gold/10">
              <svg viewBox="0 0 24 24" class="h-6 w-6 text-gold-soft" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d={pillar.icon} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="mt-6 font-display text-xl font-semibold">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/60">{pillar.text}</p>
          </Card>
        ))
      }
    </div>
  </div>
</section>
