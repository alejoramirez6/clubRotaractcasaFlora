---
interface Props {
  n: string;
  c: "gold" | "magenta";
  d: string;
}
const { n, c, d } = Astro.props;
---

<div class="rounded-2xl border border-white/10 bg-white/5 p-5 text-center">
  <p class={`font-display text-2xl font-extrabold sm:text-3xl ${c === "gold" ? "text-gold-soft" : "text-magenta-bright"}`}>
    {n}
  </p>
  <p class="mt-2 text-xs leading-relaxed text-white/50">{d}</p>
</div>
