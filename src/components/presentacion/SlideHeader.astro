---
interface Props {
  tag: string;
  kicker: string;
}
const { tag, kicker } = Astro.props;
---

<div class="mx-auto mt-16 max-w-5xl px-1">
  <p class="text-xs uppercase tracking-[0.2em] text-white/35">{tag}</p>
  <p class="mt-1 text-xs font-semibold uppercase tracking-[0.2em] text-magenta-bright">{kicker}</p>
</div>
<div class="mt-3"></div>
