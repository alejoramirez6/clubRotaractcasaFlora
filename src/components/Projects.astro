---
const areas = [
  {
    title: "Servicio Comunitario",
    text: "Jornadas de siembra de árboles y reforestación comunitaria en Cúcuta: conciencia ambiental, salud y desarrollo sostenible para las comunidades que más lo necesitan.",
    image: "/images/foto-comunidad.jpg",
  },
  {
    title: "Servicio Internacional",
    text: "Puentes de cooperación con clubes rotarios de otros países, intercambio cultural y proyectos binacionales de frontera.",
    image: "/images/foto-club.png",
  },
  {
    title: "Desarrollo Profesional",
    text: "Talleres de liderazgo y capacitaciones empresariales: formación en oratoria, networking corporativo y habilidades directivas para socios que piensan en grande.",
    image: "/images/logo-rotaract-flor.png",
  },
];
---

<section id="proyectos" class="relative py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
      <div>
        <span class="text-xs font-semibold uppercase tracking-[0.25em] text-magenta-bright">Áreas de Servicio</span>
        <h2 class="mt-4 font-display text-4xl font-bold sm:text-5xl">Proyectos que dejan huella</h2>
      </div>
      <p class="max-w-sm text-sm text-white/60">
        Cada avenida de servicio de Rotaract es una vitrina de nuestra capacidad de ejecución.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        areas.map((area) => (
          <div class="group relative aspect-[4/5] overflow-hidden rounded-2xl border border-white/10">
            <img
              src={area.image}
              alt={area.title}
              class="h-full w-full scale-105 object-cover object-center transition-transform duration-700 ease-out group-hover:scale-115"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-obsidian via-obsidian/40 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-magenta-deep/50 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

            <div class="absolute inset-x-0 bottom-0 p-7">
              <h3 class="font-display text-2xl font-bold">{area.title}</h3>
              <p class="mt-2 max-h-0 overflow-hidden text-sm leading-relaxed text-white/75 opacity-0 transition-all duration-500 group-hover:mt-3 group-hover:max-h-40 group-hover:opacity-100">
                {area.text}
              </p>
              <span class="mt-4 inline-block h-px w-10 bg-gold-soft transition-all duration-500 group-hover:w-16"></span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
