---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

interface Props {
  phone: string;
  message?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { phone, message = t("whatsapp.defaultMessage") } = Astro.props;

const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={t("whatsapp.ariaLabel")}
  class="group fixed bottom-6 right-6 z-50 flex h-16 w-16 items-center justify-center"
>
  <span
    class="absolute inset-0 rounded-full bg-emerald-500/60 animate-pulse-cta"
    aria-hidden="true"
  ></span>

  <span
    class="relative flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-emerald-600 shadow-[0_8px_30px_-6px_rgba(16,185,129,0.65)] transition-transform duration-300 group-hover:scale-110 group-hover:shadow-[0_8px_30px_-4px_rgba(209,0,116,0.55)]"
  >
    <svg
      viewBox="0 0 32 32"
      fill="currentColor"
      class="h-8 w-8 text-white"
      aria-hidden="true"
    >
      <path
        d="M16.02 3C9.4 3 4 8.36 4 15.02c0 2.37.7 4.58 1.9 6.44L4 29l7.74-1.87a12.9 12.9 0 0 0 4.28.73h.01c6.62 0 12.02-5.36 12.02-12.02C28.05 8.36 22.65 3 16.02 3Zm0 21.9h-.01a10.1 10.1 0 0 1-5.15-1.42l-.37-.22-4.6 1.1 1.13-4.47-.24-.38a9.87 9.87 0 0 1-1.52-5.29c0-5.46 4.45-9.9 9.93-9.9 2.65 0 5.14 1.03 7.01 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.46-4.45 9.9-9.93 9.9Zm5.44-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.24-.46-2.36-1.46-.87-.78-1.46-1.74-1.63-2.04-.17-.3-.02-.46.13-.61.15-.15.34-.4.5-.6.15-.2.2-.35.3-.57.1-.23.05-.4-.05-.55-.1-.15-.5-1.2-.68-1.63-.18-.42-.36-.36-.5-.37h-.42c-.15 0-.4.05-.6.27-.2.22-.78.77-.78 1.86s.8 2.15.91 2.3c.1.15 1.55 2.45 3.86 3.42 2.32.97 2.32.65 2.73.6.42-.05 1.35-.55 1.54-1.09.2-.54.2-1 .14-1.09-.05-.1-.2-.15-.5-.3Z"
      ></path>
    </svg>
  </span>
</a>
