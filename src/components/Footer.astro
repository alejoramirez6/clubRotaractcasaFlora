---
const currentYear = new Date().getFullYear();

const socials = [
  {
    label: "Instagram",
    href: "https://www.instagram.com/rotaractcasaflora/",
    comingSoon: false,
    path: "M12 2c2.7 0 3.05.01 4.12.06 1.07.05 1.8.22 2.44.47.66.26 1.22.6 1.76 1.15.55.54.9 1.1 1.15 1.76.25.64.42 1.37.47 2.44C21.99 8.95 22 9.3 22 12s-.01 3.05-.06 4.12c-.05 1.07-.22 1.8-.47 2.44a4.9 4.9 0 0 1-1.15 1.76 4.9 4.9 0 0 1-1.76 1.15c-.64.25-1.37.42-2.44.47-1.07.05-1.42.06-4.12.06s-3.05-.01-4.12-.06c-1.07-.05-1.8-.22-2.44-.47a4.9 4.9 0 0 1-1.76-1.15 4.9 4.9 0 0 1-1.15-1.76c-.25-.64-.42-1.37-.47-2.44C2.01 15.05 2 14.7 2 12s.01-3.05.06-4.12c.05-1.07.22-1.8.47-2.44.26-.66.6-1.22 1.15-1.76A4.9 4.9 0 0 1 5.44 2.53c.64-.25 1.37-.42 2.44-.47C8.95 2.01 9.3 2 12 2Zm0 1.8c-2.65 0-2.98.01-4.02.06-.87.04-1.34.18-1.66.3-.42.16-.72.36-1.03.67-.31.31-.5.6-.67 1.03-.12.32-.26.79-.3 1.66C4.28 8.7 4.27 9.03 4.27 12s.01 3.05.06 4.02c.04.87.18 1.34.3 1.66.16.42.36.72.67 1.03.31.31.6.5 1.03.67.32.12.79.26 1.66.3.99.05 1.32.06 3.99.06s3.05-.01 4.02-.06c.87-.04 1.34-.18 1.66-.3.42-.16.72-.36 1.03-.67.31-.31.5-.6.67-1.03.12-.32.26-.79.3-1.66.05-.97.06-1.32.06-4.02s-.01-3.05-.06-4.02c-.04-.87-.18-1.34-.3-1.66a2.7 2.7 0 0 0-.67-1.03 2.7 2.7 0 0 0-1.03-.67c-.32-.12-.79-.26-1.66-.3C15.05 3.8 14.72 3.8 12 3.8Zm0 3.4a4.8 4.8 0 1 1 0 9.6 4.8 4.8 0 0 1 0-9.6Zm0 1.8a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm5.15-2.9a1.13 1.13 0 1 1-2.25 0 1.13 1.13 0 0 1 2.25 0Z",
  },
  {
    label: "Facebook",
    href: "https://facebook.com/rotaractcasaflora",
    comingSoon: true,
    path: "M13.5 21v-7.2h2.4l.4-2.8h-2.8V9.1c0-.8.25-1.35 1.4-1.35H16.4V5.2c-.24-.03-1.06-.1-2-.1-2.03 0-3.4 1.24-3.4 3.5v1.9H8.6v2.8h2.4V21h2.5Z",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/company/rotaractcasaflora",
    comingSoon: true,
    path: "M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9.5h4V21H3V9.5Zm7 0h3.8v1.6h.05c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.1c0-1.22-.02-2.78-1.7-2.78-1.7 0-1.96 1.33-1.96 2.7V21h-4V9.5Z",
  },
];

const columns = [
  {
    title: "Club",
    links: [
      { label: "Quiénes Somos", href: "#quienes-somos" },
      { label: "Impacto", href: "#impacto" },
      { label: "Proyectos", href: "#proyectos" },
    ],
  },
  {
    title: "Comunidad",
    links: [
      { label: "Alianzas", href: "#alianzas" },
      { label: "Únete al Club", href: "#contacto" },
      { label: "Contacto", href: "#contacto" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Política de Privacidad", href: "/privacidad" },
      { label: "Términos de Uso", href: "/terminos" },
    ],
  },
];
---

<footer class="relative border-t border-white/10 bg-obsidian-soft">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-10">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_2fr]">
      <div>
        <div class="flex items-center gap-3">
          <img src="/images/logo-rotaract-flor.png" alt="Rotaract Casa Flora" class="h-10 w-auto" />
          <span class="font-display text-sm font-semibold uppercase tracking-[0.2em]">Casa Flora</span>
        </div>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-white/55">
          El club rotario que redefine el liderazgo joven en Cúcuta. Servicio, prestigio y una red
          profesional que trasciende fronteras.
        </p>

        <div class="mt-6 flex gap-3">
          {
            socials.map((social) =>
              social.comingSoon ? (
                <button
                  type="button"
                  data-social-soon={social.label}
                  aria-label={`${social.label} — próximamente`}
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-white/70 transition-all hover:border-gold-soft hover:text-gold-soft"
                >
                  <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor">
                    <path d={social.path} />
                  </svg>
                </button>
              ) : (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.label}
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-white/70 transition-all hover:border-magenta-bright hover:text-magenta-bright"
                >
                  <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor">
                    <path d={social.path} />
                  </svg>
                </a>
              )
            )
          }
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
        {
          columns.map((col) => (
            <div>
              <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-soft">{col.title}</h4>
              <ul class="mt-4 space-y-3">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-sm text-white/60 transition-colors hover:text-white">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
      <p class="text-xs text-white/40">
        © {currentYear} Rotaract Club Casa Flora. Todos los derechos reservados.
      </p>
      <p class="text-xs text-white/40">Cúcuta, Norte de Santander — Colombia</p>
    </div>
  </div>

  <div
    id="social-toast"
    class="pointer-events-none fixed inset-x-0 bottom-8 z-50 flex justify-center opacity-0 translate-y-3 transition-all duration-300"
  >
    <div class="flex items-center gap-2 rounded-full border border-gold-soft/30 bg-charcoal/95 px-5 py-3 text-sm text-white/90 shadow-2xl shadow-black/60 backdrop-blur">
      <svg viewBox="0 0 24 24" class="h-4 w-4 text-gold-soft" fill="currentColor">
        <path d="M12 2 9.5 8.5 3 9l5 4.5L6.5 21 12 17l5.5 4L16 13.5l5-4.5-6.5-.5Z" />
      </svg>
      <span id="social-toast-text">Muy pronto estaremos aquí</span>
    </div>
  </div>
</footer>

<script>
  const toast = document.getElementById("social-toast");
  const toastText = document.getElementById("social-toast-text");
  let hideTimeout: ReturnType<typeof setTimeout>;

  document.querySelectorAll<HTMLButtonElement>("[data-social-soon]").forEach((button) => {
    button.addEventListener("click", () => {
      const network = button.dataset.socialSoon;
      if (toastText) toastText.textContent = `Muy pronto estaremos en ${network} ✨`;
      toast?.classList.remove("opacity-0", "translate-y-3");
      toast?.classList.add("opacity-100", "translate-y-0");

      clearTimeout(hideTimeout);
      hideTimeout = setTimeout(() => {
        toast?.classList.add("opacity-0", "translate-y-3");
        toast?.classList.remove("opacity-100", "translate-y-0");
      }, 2600);
    });
  });
</script>
