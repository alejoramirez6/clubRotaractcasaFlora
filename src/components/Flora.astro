---
// Homenaje a Flora, la Gran Danés que le da nombre al club.
// Video en public/images/flora.mp4 (16:9). Vista mini fija abajo a la
// derecha; al hacer clic se abre en grande con el mensaje debajo.
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div id="flora-widget" class="fixed bottom-24 right-4 z-40 sm:bottom-28 sm:right-6">
  <button
    id="flora-trigger"
    type="button"
    aria-label={t("flora.alt")}
    class="group relative block w-36 overflow-hidden rounded-2xl border border-gold-soft/40 bg-charcoal shadow-2xl shadow-black/50 transition-transform duration-300 hover:-translate-y-1 sm:w-48"
  >
    <video
      id="flora-video-mini"
      src="/images/flora.mp4"
      class="block aspect-video w-full object-cover"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <div class="pointer-events-none absolute inset-x-0 bottom-0 flex items-center justify-between bg-gradient-to-t from-obsidian/85 to-transparent px-2.5 py-1.5">
      <span class="text-[10px] font-semibold uppercase tracking-wide text-gold-soft">🐾 Flora</span>
      <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-white/50 transition-colors group-hover:text-gold-soft" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 0 0-2 2v4m18 0V5a2 2 0 0 0-2-2h-4m0 18h4a2 2 0 0 0 2-2v-4M3 15v4a2 2 0 0 0 2 2h4" />
      </svg>
    </div>
  </button>
</div>

<div
  id="flora-modal"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-obsidian/85 p-4 backdrop-blur-sm sm:p-6"
>
  <div id="flora-modal-card" class="flora-modal-card max-h-[90vh] w-full max-w-md overflow-y-auto rounded-3xl border border-gold-soft/30 bg-charcoal p-5 shadow-2xl shadow-black/60 sm:p-8">
    <div class="flex items-center justify-between">
      <span class="text-xs font-semibold uppercase tracking-widest text-gold-soft">🐾 Flora</span>
      <button
        id="flora-modal-close"
        type="button"
        aria-label="Cerrar"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-white/60 transition-colors hover:border-gold-soft hover:text-gold-soft"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <video
      id="flora-video-modal"
      src="/images/flora.mp4"
      aria-label={t("flora.alt")}
      class="mt-4 aspect-video w-full rounded-2xl object-cover"
      muted
      loop
      playsinline
    ></video>

    <p class="mt-5 text-center text-sm leading-relaxed text-white/80">
      {t("flora.message")}
    </p>
  </div>
</div>

<script>
  const trigger = document.getElementById("flora-trigger");
  const miniVideo = document.getElementById("flora-video-mini");
  const modal = document.getElementById("flora-modal");
  const modalCard = document.getElementById("flora-modal-card");
  const modalVideo = document.getElementById("flora-video-modal");
  const closeBtn = document.getElementById("flora-modal-close");

  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    miniVideo?.pause();
  }

  function openModal() {
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    requestAnimationFrame(() => modalCard?.classList.add("is-open"));
    modalVideo?.play();
    document.body.classList.add("overflow-hidden");
  }

  function closeModal() {
    modalCard?.classList.remove("is-open");
    modalVideo?.pause();
    document.body.classList.remove("overflow-hidden");
    setTimeout(() => {
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
    }, 200);
  }

  trigger?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (event) => {
    if (event.target === modal) closeModal();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal?.classList.contains("hidden")) closeModal();
  });
</script>

<style>
  .flora-modal-card {
    opacity: 0;
    transform: scale(0.94) translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .flora-modal-card.is-open {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
</style>
