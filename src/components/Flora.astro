---
// Homenaje a Flora, la Gran Danés que le da nombre al club.
// Video en public/images/flora.mp4 (16:9), mostrado en una tarjeta fija
// abajo a la derecha, justo encima del boton de WhatsApp.
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div id="flora-widget" class="fixed bottom-24 right-4 z-40 sm:bottom-28 sm:right-6">
  <div id="flora-bubble" class="flora-bubble">
    {t("flora.message")}
    <span class="flora-bubble-arrow"></span>
  </div>

  <div
    class="relative w-36 overflow-hidden rounded-2xl border border-gold-soft/40 bg-charcoal shadow-2xl shadow-black/50 transition-transform duration-300 hover:-translate-y-1 sm:w-48"
  >
    <video
      id="flora-video"
      src="/images/flora.mp4"
      aria-label={t("flora.alt")}
      class="block aspect-video w-full object-cover"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-obsidian/85 to-transparent px-2.5 py-1.5">
      <span class="text-[10px] font-semibold uppercase tracking-wide text-gold-soft">🐾 Flora</span>
    </div>
  </div>
</div>

<script>
  const widget = document.getElementById("flora-widget");
  const bubble = document.getElementById("flora-bubble");
  const video = document.getElementById("flora-video");

  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    video?.pause();
  }

  widget?.addEventListener("click", (event) => {
    event.stopPropagation();
    bubble?.classList.toggle("is-visible");
  });

  document.addEventListener("click", (event) => {
    if (event.target instanceof Node && !widget?.contains(event.target)) {
      bubble?.classList.remove("is-visible");
    }
  });
</script>

<style>
  .flora-bubble {
    position: absolute;
    right: 0;
    bottom: calc(100% + 10px);
    width: 14rem;
    padding: 12px 16px;
    border-radius: 16px;
    border: 1px solid rgba(197, 160, 89, 0.3);
    background: rgba(11, 11, 11, 0.95);
    backdrop-filter: blur(16px);
    color: rgba(245, 243, 244, 0.85);
    font-size: 12px;
    line-height: 1.5;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .flora-bubble-arrow {
    position: absolute;
    right: 20px;
    top: 100%;
    border: 8px solid transparent;
    border-top-color: rgba(11, 11, 11, 0.95);
  }

  #flora-widget:hover .flora-bubble,
  .flora-bubble.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (hover: none) {
    #flora-widget:hover .flora-bubble {
      opacity: 0;
      transform: translateY(6px);
    }
  }
</style>
